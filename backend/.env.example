# Backend environment — copy to .env for local dev, or set these in Vercel's
# Project Settings -> Environment Variables for production.
# NEVER commit a real .env (it is gitignored).

# Supabase: enables persistent career mode. Leave blank to fall back to
# in-memory sessions (fine for a single always-on server; required on Vercel).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# The SECRET (service) key — server-side only, full DB access. Set this ONLY in
# Vercel env vars, never in the repo. Rotate immediately if it ever leaks.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx
