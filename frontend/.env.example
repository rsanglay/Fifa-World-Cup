# Frontend environment — copy to .env.local for local dev, or set in Vercel.
# Base URL of the API. Leave blank to use a same-origin "/api" (works when the
# backend is served behind the same domain, e.g. Vercel rewrites or nginx).
# For a separate backend host, set the full URL, e.g. https://your-api.vercel.app
VITE_API_URL=
